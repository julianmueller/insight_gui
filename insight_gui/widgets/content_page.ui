<?xml version="1.0" encoding="UTF-8"?>
<interface>
    <requires lib="gtk" version="4.0" />
    <requires lib="adw" version="1.0" />


    <object class="AdwToolbarView" id="toolbar_view">
        <!-- <property name="top-bar-style">raised</property>
                <property name="bottom-bar-style">raised</property>
                <property name="extend-content-to-bottom-edge">True</property> -->

        <child type="top">
            <object class="AdwHeaderBar" id="header_bar">
                <child type="start">
                    <object class="GtkToggleButton" id="search_btn">
                        <property name="icon-name">search-symbolic</property>
                        <property name="tooltip-text">Search</property>
                    </object>
                </child>
                <child type="start">
                    <object class="GtkButton" id="refresh_btn">
                        <property name="tooltip-text">Refresh</property>
                        <child>
                            <object class="GtkBox">
                                <child>
                                    <object class="GtkImage" id="refresh_icon">
                                        <property name="visible">true</property>
                                        <property name="icon-name">update-symbolic</property>
                                    </object>
                                </child>
                                <child>
                                    <object class="GtkSpinner" id="refresh_spinner">
                                        <property name="visible">false</property>
                                        <property name="spinning">false</property>
                                    </object>
                                </child>
                            </object>
                        </child>

                        <style>
                            <class name="flat" />
                        </style>
                    </object>
                </child>

                <child type="end">
                    <object class="GtkButton" id="dedock_btn">
                        <property name="icon-name">external-link-symbolic</property>
                        <property name="tooltip-text">Open in separate window</property>
                        <property name="visible">false</property>
                    </object>
                </child>
            </object>
        </child>

        <child type="top">
            <object class="GtkSearchBar" id="search_bar">
                <property name="search-mode-enabled">False</property>
                <property name="show-close-button">True</property>
                <child>
                    <object class="GtkSearchEntry" id="search_entry">
                        <property name="placeholder-text">Search</property>
                        <property name="search-delay">100</property>
                        <property name="width-request">300</property>
                    </object>
                </child>
            </object>
        </child>

        <child>
            <object class="AdwToastOverlay" id="toast_overlay">
                <child>
                    <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <child>
                            <object class="AdwBanner" id="banner">
                                <property name="revealed">false</property>
                            </object>
                        </child>
                        <child>
                            <object class="GtkStack" id="content_stack">
                                <property name="vexpand">True</property>
                                <child>
                                    <object class="AdwStatusPage" id="refresh_page">
                                        <property name="title">No Content</property>
                                        <property name="description">Refresh to show content. This may take a second.</property>
                                        <property name="icon-name">update-symbolic</property>
                                        <child>
                                            <object class="GtkButton">
                                                <property name="halign">center</property>
                                                <property name="child">
                                                    <object class="AdwButtonContent">
                                                        <property name="label">Refresh</property>
                                                        <property name="icon-name">update-symbolic</property>
                                                    </object>
                                                </property>
                                                <style>
                                                    <class name="pill" />
                                                </style>
                                            </object>
                                        </child>
                                    </object>
                                </child>
                                <child>
                                    <object class="AdwStatusPage" id="empty_search_page">
                                        <property name="title">No Search Results</property>
                                        <property name="description">Search found no results.</property>
                                        <property name="icon-name">search-symbolic</property>
                                    </object>
                                </child>
                            </object>
                        </child>
                    </object>
                </child>
            </object>
        </child>

        <child type="bottom">
            <object class="GtkActionBar" id="bottom_bar">
                <property name="revealed">false</property>
                <!-- <property name="valign">2</property> -->
                <!-- <child type="start">
                            <object class="GtkButton" id="start_widget">
                                <property name="icon-name">call-start-symbolic</property>
                            </object>
                        </child>
                        <child type="center">
                            <object class="GtkLabel">
                                <property name="label" translatable="yes">Action Bar</property>
                            </object>
                        </child>
                        <child type="end">
                            <object class="GtkButton" id="end_widget">
                                <property name="icon-name">view-more-symbolic</property>
                            </object>
                        </child> -->
            </object>
        </child>
    </object>
</interface>